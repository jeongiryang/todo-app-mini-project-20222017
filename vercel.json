{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/proxy/weather",
      "dest": "https://api.open-meteo.com/v1/forecast"
    },
    {
      "src": "/proxy/dust",
      "dest": "https://air-quality-api.open-meteo.com/v1/air-quality"
    },

    {
      "src": "/api/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/(assets/.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*\\.(js|css|ico|svg|png|jpg|jpeg|gif))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}